<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Odyssey</li>
    </mods>
    <nomatch Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationConditional">
          <xpath>/Defs/BodyDef[defName="Larva"]</xpath>
          <nomatch Class="PatchOperationAdd">
            <xpath>/Defs</xpath>
            <value>
              <BodyDef>
                <defName>Larva</defName>
                <label>larva</label>
                <corePart>
                  <def>Shell</def>
                  <height>Middle</height>
                  <depth>Outside</depth>
                  <parts>
                    <li>
                      <def>Stomach</def>
                      <coverage>0.05</coverage>
                      <depth>Inside</depth>
                    </li>
                    <li>
                      <def>InsectHeart</def>
                      <coverage>0.03</coverage>
                      <depth>Inside</depth>
                    </li>
                    <li>
                      <def>Pronotum</def>
                      <coverage>0.18</coverage>
                      <height>Top</height>
                      <parts>
                        <li>
                          <def>InsectHead</def>
                          <coverage>0.65</coverage>
                          <groups>
                            <li>HeadAttackTool</li>
                          </groups>
                          <parts>
                            <li>
                              <def>Brain</def>
                              <coverage>0.2</coverage>
                              <depth>Inside</depth>
                            </li>
                            <li>
                              <def>Eye</def>
                              <customLabel>left eye</customLabel>
                              <coverage>0.15</coverage>
                            </li>
                            <li>
                              <def>Eye</def>
                              <customLabel>right eye</customLabel>
                              <coverage>0.15</coverage>
                            </li>
                            <li>
                              <def>Antenna</def>
                              <coverage>0.10</coverage>
                              <customLabel>left antenna</customLabel>
                            </li>
                            <li>
                              <def>Antenna</def>
                              <coverage>0.10</coverage>
                              <customLabel>right antenna</customLabel>
                            </li>
                            <li>
                              <def>InsectNostril</def>
                              <coverage>0.07</coverage>
                            </li>
                            <li>
                              <def>InsectMouth</def>
                              <coverage>0.10</coverage>
                              <groups>
                                <li>Mouth</li>
                              </groups>
                            </li>
                          </parts>
                        </li>
                      </parts>
                    </li>
                    <li>
                      <def>InsectLeg</def>
                      <customLabel>front left leg</customLabel>
                      <coverage>0.06</coverage>
                      <height>Bottom</height>
                    </li>
                    <li>
                      <def>InsectLeg</def>
                      <customLabel>front right leg</customLabel>
                      <coverage>0.06</coverage>
                      <height>Bottom</height>
                    </li>
                    <li>
                      <def>InsectLeg</def>
                      <customLabel>middle left leg</customLabel>
                      <coverage>0.06</coverage>
                      <height>Bottom</height>
                    </li>
                    <li>
                      <def>InsectLeg</def>
                      <customLabel>middle right leg</customLabel>
                      <coverage>0.06</coverage>
                      <height>Bottom</height>
                    </li>
                    <li>
                      <def>InsectLeg</def>
                      <customLabel>rear left leg</customLabel>
                      <coverage>0.06</coverage>
                      <height>Bottom</height>
                    </li>
                    <li>
                      <def>InsectLeg</def>
                      <customLabel>rear right leg</customLabel>
                      <coverage>0.06</coverage>
                      <height>Bottom</height>
                    </li>
                  </parts>
                </corePart>
              </BodyDef>
            </value>
          </nomatch>
        </li>

		<li Class="PatchOperationFindMod">
		  <mods>
			<li>Combat Extended</li>
		  </mods>
		  <match Class="PatchOperationSequence">
			<operations>
			  <li Class="PatchOperationConditional">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/groups</xpath>
				<nomatch Class="PatchOperationAdd">
				  <xpath>Defs/BodyDef[defName="Larva"]/corePart</xpath>
				  <value>
					<groups />
				  </value>
				</nomatch>
			  </li>
			  <li Class="PatchOperationConditional">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/groups</xpath>
				<nomatch Class="PatchOperationAdd">
				  <xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]</xpath>
				  <value>
					<groups />
				  </value>
				</nomatch>
			  </li>
			  <li Class="PatchOperationConditional">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]/groups</xpath>
				<nomatch Class="PatchOperationAdd">
				  <xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]</xpath>
				  <value>
					<groups />
				  </value>
				</nomatch>
			  </li>
			  <li Class="PatchOperationConditional">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]/parts/li[def="Antenna"]/groups</xpath>
				<nomatch Class="PatchOperationAdd">
				  <xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]/parts/li[def="Antenna"]</xpath>
				  <value>
					<groups />
				  </value>
				</nomatch>
			  </li>
			  <li Class="PatchOperationConditional">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]/parts/li[def="InsectNostril"]/groups</xpath>
				<nomatch Class="PatchOperationAdd">
				  <xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]/parts/li[def="InsectNostril"]</xpath>
				  <value>
					<groups />
				  </value>
				</nomatch>
			  </li>
			  <li Class="PatchOperationConditional">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]/parts/li[def="InsectMouth"]/groups</xpath>
				<nomatch Class="PatchOperationAdd">
				  <xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]/parts/li[def="InsectMouth"]</xpath>
				  <value>
					<groups />
				  </value>
				</nomatch>
			  </li>
			  <li Class="PatchOperationConditional">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="InsectLeg"]/groups</xpath>
				<nomatch Class="PatchOperationAdd">
				  <xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="InsectLeg"]</xpath>
				  <value>
					<groups />
				  </value>
				</nomatch>
			  </li>

			  <li Class="PatchOperationAdd">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/groups</xpath>
				<value>
				  <li>CoveredByNaturalArmor</li>
				</value>
			  </li>
			  <li Class="PatchOperationAdd">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/groups</xpath>
				<value>
				  <li>CoveredByNaturalArmor</li>
				</value>
			  </li>
			  <li Class="PatchOperationAdd">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]/groups</xpath>
				<value>
				  <li>CoveredByNaturalArmor</li>
				</value>
			  </li>
			  <li Class="PatchOperationAdd">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]/parts/li[def="Antenna"]/groups</xpath>
				<value>
				  <li>CoveredByNaturalArmor</li>
				</value>
			  </li>
			  <li Class="PatchOperationAdd">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]/parts/li[def="InsectNostril"]/groups</xpath>
				<value>
				  <li>CoveredByNaturalArmor</li>
				</value>
			  </li>
			  <li Class="PatchOperationAdd">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="Pronotum"]/parts/li[def="InsectHead"]/parts/li[def="InsectMouth"]/groups</xpath>
				<value>
				  <li>CoveredByNaturalArmor</li>
				</value>
			  </li>
			  <li Class="PatchOperationAdd">
				<xpath>Defs/BodyDef[defName="Larva"]/corePart/parts/li[def="InsectLeg"]/groups</xpath>
				<value>
				  <li>CoveredByNaturalArmor</li>
				</value>
			  </li>
			</operations>
		  </match>
		</li>
      </operations>
    </nomatch>
  </Operation>
</Patch>