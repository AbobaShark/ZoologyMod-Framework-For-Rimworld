<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<!-- Pangolin replace EatAntsWhenHungry with AutoNutrition safely -->
	<Operation Class="PatchOperationFindMod">
	  <mods>
		<li>Vanilla Animals Expanded — Endangered</li>
	  </mods>
	  <match Class="PatchOperationSequence">
		<operations>
		  <!-- Remove existing EatAntsWhenHungry -->
		  <li Class="PatchOperationConditional">
			<xpath>Defs/ThingDef[defName="AEXP_Pangolin"]/comps/li[@Class="VanillaAnimalsExpandedEndangered.CompProperties_EatAntsWhenHungry"]</xpath>
			<match Class="PatchOperationRemove">
			  <xpath>Defs/ThingDef[defName="AEXP_Pangolin"]/comps/li[@Class="VanillaAnimalsExpandedEndangered.CompProperties_EatAntsWhenHungry"]</xpath>
			</match>
		  </li>
		  <!-- Add AutoNutrition -->
		  <li Class="PatchOperationConditional">
			<xpath>Defs/ThingDef[defName="AEXP_Pangolin"]/comps/li[@Class="VEF.AnimalBehaviours.CompProperties_AutoNutrition"]</xpath>
			<nomatch Class="PatchOperationAdd">
			  <xpath>Defs/ThingDef[defName="AEXP_Pangolin"]/comps</xpath>
			  <value>
				<li Class="VEF.AnimalBehaviours.CompProperties_AutoNutrition">
				  <tickInterval>2000</tickInterval>
				  <consumingFoodReportString>Eating ants</consumingFoodReportString>
				</li>
			  </value>
			</nomatch>
		  </li>
		</operations>
	  </match>
	</Operation>
	
