<?xml version="1.0" encoding="utf-8" ?>
<Patch>

	<!-- =========================================================
		 Husky – AnimalCrossbreedExtension (safe replace/add)
		 ========================================================= -->
	<Operation Class="PatchOperationConditional">
	  <xpath>
		Defs/ThingDef[defName="Husky"]/modExtensions/li[@Class="VEF.AnimalBehaviours.AnimalCrossbreedExtension"]
	  </xpath>
	  <!-- Если расширение уже есть — заменяем -->
	  <match Class="PatchOperationReplace">
		<xpath>
		  Defs/ThingDef[defName="Husky"]/modExtensions/li[@Class="VEF.AnimalBehaviours.AnimalCrossbreedExtension"]
		</xpath>
		<value>
		  <li Class="VEF.AnimalBehaviours.AnimalCrossbreedExtension">
			<crossBreedKindDef>Random</crossBreedKindDef>
		  </li>
		</value>
	  </match>
	  <!-- Если расширения нет — добавляем -->
	  <nomatch Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[defName="Husky"]</xpath>
		<value>
		  <li Class="VEF.AnimalBehaviours.AnimalCrossbreedExtension">
			<crossBreedKindDef>Random</crossBreedKindDef>
		  </li>
		</value>
	  </nomatch>
	</Operation>
	
