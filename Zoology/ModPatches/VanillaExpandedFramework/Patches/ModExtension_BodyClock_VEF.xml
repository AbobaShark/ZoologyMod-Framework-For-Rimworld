  <!-- ===================== -->

  <!-- Cassowary -->
  <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName='Cassowary']/modExtensions/li[@Class='VEF.AnimalBehaviours.ExtendedRaceProperties']</xpath>
    <nomatch Class="PatchOperationAddModExtension">
      <xpath>Defs/ThingDef[defName='Cassowary']</xpath>
      <value>
        <li Class="VEF.AnimalBehaviours.ExtendedRaceProperties">
          <bodyClock>Crepuscular</bodyClock>
        </li>
      </value>
    </nomatch>
  </Operation>

