<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- Toxiguana -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAEWaste_Toxiguana"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAEWaste_Toxiguana"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
      <value><eggLayIntervalDays>60.0</eggLayIntervalDays></value>
    </match>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAEWaste_Toxiguana"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAEWaste_Toxiguana"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
      <value><eggCountRange>30~60</eggCountRange></value>
    </match>
  </Operation>
  
  <!-- VasteHydra -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAEWaste_Hydra"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAEWaste_Hydra"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
      <value><eggLayIntervalDays>60.0</eggLayIntervalDays></value>
    </match>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAEWaste_Hydra"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAEWaste_Hydra"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
      <value><eggCountRange>20~35</eggCountRange></value>
    </match>
  </Operation>

</Patch>