<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- Toxiguana -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAEWaste_Toxiguana"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAEWaste_Toxiguana"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
      <value>60.0</value>
    </match>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAEWaste_Toxiguana"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAEWaste_Toxiguana"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
      <value>30~60</value>
    </match>
  </Operation>
  
  <!-- VasteHydra -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAEWaste_Hydra"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAEWaste_Hydra"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
      <value>60.0</value>
    </match>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAEWaste_Hydra"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAEWaste_Hydra"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
      <value>20~35</value>
    </match>
  </Operation>

</Patch>