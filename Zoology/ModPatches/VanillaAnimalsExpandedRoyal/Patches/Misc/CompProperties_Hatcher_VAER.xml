<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- VAERoy: Crane egg (fert.) -> hatcherDaystoHatch = 5 -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_EggCraneFertilized"]/comps/li[Class="CompProperties_Hatcher"]/hatcherDaystoHatch/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_EggCraneFertilized"]/comps/li[Class="CompProperties_Hatcher"]/hatcherDaystoHatch/text()</xpath>
      <value>5</value>
    </match>
  </Operation>

