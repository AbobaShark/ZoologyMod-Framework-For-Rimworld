<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- Pheasant -> eggLayIntervalDays = 60.0, eggCountRange = 10~15 -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Pheasant"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Pheasant"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
      <value>60.0</value>
    </match>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Pheasant"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Pheasant"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
      <value>10~15</value>
    </match>
  </Operation>

  <!-- Megachicken -> eggLayIntervalDays = 1.0, eggCountRange = 1 -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Megachicken"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Megachicken"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
      <value>1.0</value>
    </match>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Megachicken"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Megachicken"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
      <value>1</value>
    </match>
  </Operation>

  <!-- Crane -> eggLayIntervalDays = 60.0, eggCountRange = 1~3 -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Crane"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Crane"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
      <value>60.0</value>
    </match>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Crane"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Crane"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
      <value>1~3</value>
    </match>
  </Operation>

</Patch>