<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- Pheasant -> eggLayIntervalDays = 60.0, eggCountRange = 10~15 -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Pheasant"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Pheasant"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
      <value><eggLayIntervalDays>60.0</eggLayIntervalDays></value>
    </match>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Pheasant"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Pheasant"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
      <value><eggCountRange>10~15</eggCountRange></value>
    </match>
  </Operation>

  <!-- Megachicken -> eggLayIntervalDays = 1.0, eggCountRange = 1 -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Megachicken"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Megachicken"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
      <value><eggLayIntervalDays>1.0</eggLayIntervalDays></value>
    </match>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Megachicken"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Megachicken"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
      <value><eggCountRange>1</eggCountRange></value>
    </match>
  </Operation>

  <!-- Crane -> eggLayIntervalDays = 60.0, eggCountRange = 1~3 -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Crane"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Crane"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
      <value><eggLayIntervalDays>60.0</eggLayIntervalDays></value>
    </match>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="VAERoy_Crane"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="VAERoy_Crane"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
      <value><eggCountRange>1~3</eggCountRange></value>
    </match>
  </Operation>

</Patch>