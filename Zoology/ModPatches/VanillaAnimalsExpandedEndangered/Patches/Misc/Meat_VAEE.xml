<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <!-- =================================================
       Primates
       ================================================= -->
  <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName="AEXP_Bonobo"]/race/useMeatFrom</xpath>
    <match Class="PatchOperationReplace">
      <xpath>Defs/ThingDef[defName="AEXP_Bonobo"]/race/useMeatFrom</xpath>
      <value>
        <useMeatFrom>Monkey</useMeatFrom>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>Defs/ThingDef[defName="AEXP_Bonobo"]/race</xpath>
      <value>
        <useMeatFrom>Monkey</useMeatFrom>
      </value>
    </nomatch>
  </Operation>
</Patch>