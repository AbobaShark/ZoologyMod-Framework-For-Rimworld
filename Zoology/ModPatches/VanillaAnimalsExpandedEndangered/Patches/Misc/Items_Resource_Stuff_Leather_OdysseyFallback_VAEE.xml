<?xml version='1.0' encoding='UTF-8'?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Odyssey</li>
    </mods>
    <nomatch Class="PatchOperationSequence">
      <operations>
        <!-- Odyssey fallback defs for VAEE leathers (only when Odyssey is absent) -->
        <li Class="PatchOperationConditional">
          <xpath>/Defs/ThingDef[defName="Leather_Armadillo"]</xpath>
          <nomatch Class="PatchOperationAdd">
            <xpath>/Defs</xpath>
            <value><ThingDef ParentName="LeatherBase">
    <defName>Leather_Armadillo</defName>
    <label>armadillo leather</label>
    <description>Tanned, dried, scraped armadillo skin. It's tough, but offers little protection against the elements.</description>
    <graphicData>
      <color>(204,154,104)</color>
    </graphicData>
    <statBases>
      <MarketValue>3.2</MarketValue>
      <StuffPower_Armor_Sharp>1.24</StuffPower_Armor_Sharp>
      <StuffPower_Insulation_Cold>16</StuffPower_Insulation_Cold>
      <StuffPower_Insulation_Heat>18</StuffPower_Insulation_Heat>
    </statBases>
    <stuffProps>
      <color>(204,154,104)</color>
      <commonality>0.01</commonality>
      <statFactors>
        <MaxHitPoints>1.3</MaxHitPoints>
        <Beauty>2</Beauty>
      </statFactors>
    </stuffProps>
  </ThingDef>
  
</value>
          </nomatch>
        </li>
        <!-- CE adjustments for fallback leather defs (only when CE present) -->
        <li Class="PatchOperationFindMod">
          <mods>
            <li>Combat Extended</li>
          </mods>
          <match Class="PatchOperationSequence">
            <operations><li Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="Leather_Armadillo"]/statBases/StuffPower_Armor_Sharp</xpath>
		<value>
			<StuffPower_Armor_Sharp>0.09</StuffPower_Armor_Sharp>
		</value>
	</li>

	<li Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Leather_Armadillo"]/statBases</xpath>
		<value>
			<StuffPower_Armor_Blunt>0.064</StuffPower_Armor_Blunt>
		</value>
	</li>

</operations>
          </match>
        </li>
      </operations>
    </nomatch>
  </Operation>
</Patch>
