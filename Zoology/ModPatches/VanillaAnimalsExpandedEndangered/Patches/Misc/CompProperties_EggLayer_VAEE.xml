<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- RockhopperPenguin -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_RockhopperPenguin"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_RockhopperPenguin"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
      <value><eggLayIntervalDays>60.0</eggLayIntervalDays></value>
    </match>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_RockhopperPenguin"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_RockhopperPenguin"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
      <value><eggCountRange>1~3</eggCountRange></value>
    </match>
  </Operation>
  
  <!-- Moa -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_Moa"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_Moa"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
      <value><eggLayIntervalDays>3.0</eggLayIntervalDays></value>
    </match>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_Moa"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_Moa"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
      <value><eggCountRange>1~2</eggCountRange></value>
    </match>
  </Operation>

</Patch>