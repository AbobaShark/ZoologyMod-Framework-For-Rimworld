<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- RockhopperPenguin -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_RockhopperPenguin"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_RockhopperPenguin"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
      <value>60.0</value>
    </match>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_RockhopperPenguin"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_RockhopperPenguin"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
      <value>1~3</value>
    </match>
  </Operation>
  
  <!-- Moa -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_Moa"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_Moa"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
      <value>3.0</value>
    </match>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_Moa"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_Moa"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
      <value>1~2</value>
    </match>
  </Operation>

</Patch>