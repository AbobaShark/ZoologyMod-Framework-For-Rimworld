<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- ===================== -->
  <!-- Crepuscular           -->
  <!-- ===================== -->

  <!-- AEXP_Hyena -->
  <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName='AEXP_Hyena']/modExtensions/li[@Class='VEF.AnimalBehaviours.ExtendedRaceProperties']</xpath>
    <nomatch Class="PatchOperationAddModExtension">
      <xpath>Defs/ThingDef[defName='AEXP_Hyena']</xpath>
      <value>
        <li Class="VEF.AnimalBehaviours.ExtendedRaceProperties">
          <bodyClock>Crepuscular</bodyClock>
        </li>
      </value>
    </nomatch>
  </Operation>

