<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- ============================
       A) Ensure <comps> exists for animals we will add full milkable blocks to
       (add <comps/> to ThingDef if it's missing)
       ============================ -->

  <!-- Dromedary: ensure comps exists -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="Dromedary"]/comps</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName="Dromedary"]</xpath>
      <value>
        <comps />
      </value>
    </nomatch>
  </Operation>

  <!-- ============================
       B) Replace or add full <li Class="CompProperties_Shearable">
       (for Dromedary we want to set full block)
       ============================ -->

  <!-- Dromedary: replace if exists, otherwise add li under comps -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="Dromedary"]/comps/li[Class="CompProperties_Shearable"]</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="Dromedary"]/comps/li[Class="CompProperties_Shearable"]</xpath>
      <value>
		  <li Class="CompProperties_Shearable">
			<woolDef>WoolCamel</woolDef>
			<shearIntervalDays>15</shearIntervalDays>
			<woolAmount>120</woolAmount>
		  </li>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName="Dromedary"]/comps</xpath>
      <value>
		  <li Class="CompProperties_Shearable">
			<woolDef>WoolCamel</woolDef>
			<shearIntervalDays>15</shearIntervalDays>
			<woolAmount>120</woolAmount>
		  </li>
      </value>
    </nomatch>
  </Operation>

</Patch>
