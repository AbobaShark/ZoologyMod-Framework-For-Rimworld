<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- AEXP: Crocodile animal egg-layer -> eggLayIntervalDays = 60.0, eggCountRange = 40~80 -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_Crocodile"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_Crocodile"]/comps/li[@Class="CompProperties_EggLayer"]/eggLayIntervalDays</xpath>
      <value><eggLayIntervalDays>60.0</eggLayIntervalDays></value>
    </match>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_Crocodile"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_Crocodile"]/comps/li[@Class="CompProperties_EggLayer"]/eggCountRange</xpath>
      <value><eggCountRange>35~65</eggCountRange></value>
    </match>
  </Operation>

