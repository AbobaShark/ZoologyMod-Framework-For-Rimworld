  <!-- Remove egg-layer comp on AEXP_Anaconda (they are eggviviparous in this mod) -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_Anaconda"]/comps/li[@Class="CompProperties_EggLayer"]</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/ThingDef[defName="AEXP_Anaconda"]/comps/li[@Class="CompProperties_EggLayer"]</xpath>
    </match>
  </Operation>
  
  <Operation Class="PatchOperationRemove">
	<xpath>Defs/ThingDef[defName="AEXP_EggAnacondaUnfertilized"]</xpath>
  </Operation>
  
  <Operation Class="PatchOperationRemove">
	<xpath>Defs/ThingDef[defName="AEXP_EggAnacondaFertilized"]</xpath>
  </Operation>
  
