<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- AEXP: Crocodile animal egg-layer -> eggLayIntervalDays = 60.0, eggCountRange = 40~80 -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_Crocodile"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_Crocodile"]/comps/li[Class="CompProperties_EggLayer"]/eggLayIntervalDays/text()</xpath>
      <value>60.0</value>
    </match>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName="AEXP_Crocodile"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName="AEXP_Crocodile"]/comps/li[Class="CompProperties_EggLayer"]/eggCountRange/text()</xpath>
      <value>35~65</value>
    </match>
  </Operation>

