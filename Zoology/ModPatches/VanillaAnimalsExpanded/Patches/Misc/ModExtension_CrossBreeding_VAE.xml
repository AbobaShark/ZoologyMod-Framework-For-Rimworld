<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- AEXP_ArcticCoyote -->

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "AEXP_ArcticCoyote"]/race/canCrossBreedWith</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "AEXP_ArcticCoyote"]/race/canCrossBreedWith</xpath>
      <value>
	    <canCrossBreedWith>
			<li>AEXP_Coyote</li>
		</canCrossBreedWith>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "AEXP_ArcticCoyote"]/race</xpath>
      <value>
	    <canCrossBreedWith>
			<li>AEXP_Coyote</li>
		</canCrossBreedWith>
      </value>
    </nomatch>
  </Operation>
  
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "AEXP_ArcticCoyote"]/race/crossAggroWith</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "AEXP_ArcticCoyote"]/race/crossAggroWith</xpath>
      <value>
	    <crossAggroWith>
			<li>AEXP_Coyote</li>
		</crossAggroWith>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "AEXP_ArcticCoyote"]/race</xpath>
      <value>
	    <crossAggroWith>
			<li>AEXP_Coyote</li>
		</crossAggroWith>
      </value>
    </nomatch>
  </Operation>
  
	<!-- =========================================================
		 AEXP_ArcticCoyote – AnimalCrossbreedExtension (safe replace/add)
		 ========================================================= -->
	<Operation Class="PatchOperationConditional">
	  <xpath>
		Defs/ThingDef[defName="AEXP_ArcticCoyote"]/modExtensions/li[@Class="VEF.AnimalBehaviours.AnimalCrossbreedExtension"]
	  </xpath>
	  <!-- Если расширение уже есть — заменяем -->
	  <match Class="PatchOperationReplace">
		<xpath>
		  Defs/ThingDef[defName="AEXP_ArcticCoyote"]/modExtensions/li[@Class="VEF.AnimalBehaviours.AnimalCrossbreedExtension"]
		</xpath>
		<value>
		  <li Class="VEF.AnimalBehaviours.AnimalCrossbreedExtension">
			<crossBreedKindDef>Random</crossBreedKindDef>
		  </li>
		</value>
	  </match>
	  <!-- Если расширения нет — добавляем -->
	  <nomatch Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[defName="AEXP_ArcticCoyote"]</xpath>
		<value>
		  <li Class="VEF.AnimalBehaviours.AnimalCrossbreedExtension">
			<crossBreedKindDef>Random</crossBreedKindDef>
		  </li>
		</value>
	  </nomatch>
	</Operation>


