<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- =======================================================================
		 Set leatherDef for AEXP_Wildebeest -> Leather_Plain
		 ======================================================================= -->
	<Operation Class="PatchOperationConditional">
	  <xpath>Defs/ThingDef[defName="AEXP_Wildebeest"]/race/leatherDef</xpath>
	  <nomatch Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="AEXP_Wildebeest"]/race</xpath>
		<value>
		  <leatherDef>Leather_Plain</leatherDef>
		</value>
	  </nomatch>
	  <match Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="AEXP_Wildebeest"]/race/leatherDef</xpath>
		<value>
		  <leatherDef>Leather_Plain</leatherDef>
		</value>
	  </match>
	</Operation>
	
	<Operation Class="PatchOperationRemove">
	  <xpath>Defs/ThingDef[defName="AEXP_Leather_Wildebeest"]</xpath>
	</Operation>
	
