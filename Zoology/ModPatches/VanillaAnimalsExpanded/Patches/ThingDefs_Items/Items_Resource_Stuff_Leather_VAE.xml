<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- =======================================================================
		 Remove leathers
		 ======================================================================= -->
	
	<Operation Class="PatchOperationRemove">
	  <xpath>Defs/ThingDef[defName="AEXP_Leather_Wildebeest"]</xpath>
	</Operation>
	
	<Operation Class="PatchOperationRemove">
	  <xpath>Defs/ThingDef[defName="AEXP_Leather_Platypus"]</xpath>
	</Operation>
	
	<Operation Class="PatchOperationRemove">
	  <xpath>Defs/ThingDef[defName="AEXP_Leather_Lion"]</xpath>
	</Operation>
	
	<!-- =======================================================================
		 Set stats for WoolCamel
		 ======================================================================= -->
	
    <Operation Class="PatchOperationConditional">
      <xpath>Defs/ThingDef[defName="WoolCamel"]/statBases/StuffPower_Insulation_Cold</xpath>
      <match Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="WoolCamel"]/statBases/StuffPower_Insulation_Cold</xpath>
        <value><StuffPower_Insulation_Cold>28</StuffPower_Insulation_Cold></value>
      </match>
      <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="WoolCamel"]/statBases</xpath>
        <value><StuffPower_Insulation_Cold>28</StuffPower_Insulation_Cold></value>
      </nomatch>
    </Operation>
  
    <Operation Class="PatchOperationConditional">
      <xpath>Defs/ThingDef[defName="WoolCamel"]/statBases/StuffPower_Insulation_Heat</xpath>
      <match Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="WoolCamel"]/statBases/StuffPower_Insulation_Heat</xpath>
        <value><StuffPower_Insulation_Heat>14</StuffPower_Insulation_Heat></value>
      </match>
      <nomatch Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="WoolCamel"]/statBases</xpath>
        <value><StuffPower_Insulation_Heat>14</StuffPower_Insulation_Heat></value>
      </nomatch>
    </Operation>

</Patch>
