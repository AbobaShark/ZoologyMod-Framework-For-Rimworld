<?xml version='1.0' encoding='UTF-8'?>
<Patch>
  <!-- Добавление животных -->
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Odyssey</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <!-- Caravan animals -->
        <li Class="PatchOperationConditional">
          <xpath>/Defs/BiomeDef[defName="Grasslands"]/allowedPackAnimals/li[text()="AEXP_Camel"]</xpath>
          <nomatch Class="PatchOperationAdd">
            <xpath>/Defs/BiomeDef[defName="Grasslands"]/allowedPackAnimals</xpath>
            <value>
              <li>AEXP_Camel</li>
            </value>
          </nomatch>
        </li>
      </operations>
    </match>
  </Operation>
</Patch>
