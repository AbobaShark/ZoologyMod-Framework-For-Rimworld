<?xml version='1.0' encoding='UTF-8'?>
<Patch>
  <!-- Caravan animals -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="AridShrubland"]/allowedPackAnimals/li[text()="AEXP_Camel"]</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/BiomeDef[defName="AridShrubland"]/allowedPackAnimals</xpath>
      <value>
        <li>AEXP_Camel</li>
      </value>
    </nomatch>
  </Operation>
</Patch>
