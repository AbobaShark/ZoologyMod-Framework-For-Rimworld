<?xml version='1.0' encoding='utf-8'?>
<Patch>

    <!-- Добавление животных -->
	
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Odyssey</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
		<!-- Caravan animals -->
		<li Class="PatchOperationAdd"> 
			<xpath>/Defs/BiomeDef[defName="Glowforest"]/allowedPackAnimals</xpath>
			<value>
				<li>AEXP_IndianElephant</li>
			</value>
		</li>
      </operations>
    </match>
  </Operation>
</Patch>