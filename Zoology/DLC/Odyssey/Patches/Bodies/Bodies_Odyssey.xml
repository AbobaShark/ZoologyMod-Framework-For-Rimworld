<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- Pinniped (обычный и с клыками) — объединённые патчи для внутренних органов -->
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Spine"]/coverage</xpath>
    <value><coverage>0.025</coverage></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Stomach"]/coverage</xpath>
    <value><coverage>0.025</coverage></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Heart"]/coverage</xpath>
    <value><coverage>0.020</coverage></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Lung" and customLabel="left lung"]/coverage</xpath>
    <value><coverage>0.025</coverage></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Lung" and customLabel="right lung"]/coverage</xpath>
    <value><coverage>0.025</coverage></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Kidney" and customLabel="left kidney"]/coverage</xpath>
    <value><coverage>0.017</coverage></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Kidney" and customLabel="right kidney"]/coverage</xpath>
    <value><coverage>0.017</coverage></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Liver"]/coverage</xpath>
    <value><coverage>0.025</coverage></value>
  </Operation>

  <!-- Pinniped head (оба типа используют HeadWithEarHoles) -->
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Neck"]/parts/li[def="HeadWithEarHoles"]/parts/li[def="Eye" and customLabel="left eye"]/coverage</xpath>
    <value><coverage>0.025</coverage></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Neck"]/parts/li[def="HeadWithEarHoles"]/parts/li[def="Eye" and customLabel="right eye"]/coverage</xpath>
    <value><coverage>0.025</coverage></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Neck"]/parts/li[def="HeadWithEarHoles"]/parts/li[def="AnimalJaw"]/coverage</xpath>
    <value><coverage>0.15</coverage></value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/BodyDef[defName="Pinniped" or defName="PinnipedWithTusks"]/corePart/parts/li[def="Neck"]/parts/li[def="HeadWithEarHoles"]/parts/li[def="Skull"]/parts/li[def="Brain"]/coverage</xpath>
    <value><coverage>0.4</coverage></value>
  </Operation>

</Patch>
