<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="Scarlands"]/wildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="Scarlands"]/wildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Scarlands"]</xpath>
    <value>
      <wildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="Scarlands"]/pollutionWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="Scarlands"]/pollutionWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Scarlands"]</xpath>
    <value>
      <pollutionWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="Scarlands"]/coastalWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="Scarlands"]/coastalWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Scarlands"]</xpath>
    <value>
      <coastalWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="Scarlands"]/allowedPackAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="Scarlands"]/allowedPackAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Scarlands"]</xpath>
    <value>
      <allowedPackAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Scarlands"]/wildAnimals</xpath>
    <value>
      <Raccoon>0.375</Raccoon>
      <Dromedary>0.15</Dromedary>
      <Cat>0.1</Cat>
      <Horse>0.15</Horse>
      <Donkey>0.175</Donkey>
      <WildBoar>0.175</WildBoar>
      <Pig>0.15</Pig>
      <Rat>1</Rat>
      <Boomrat>0.15</Boomrat>
      <Boomalope>0.1</Boomalope>
      <Warg>0.05</Warg>
      <Sparrow>1</Sparrow>
      <Crow>1</Crow>
      <BogHound>0.05</BogHound>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Scarlands"]/pollutionWildAnimals</xpath>
    <value>
      <Raccoon>0.3</Raccoon>
      <WildBoar>0.15</WildBoar>
      <Rat>0.8</Rat>
      <Boomrat>0.15</Boomrat>
      <Boomalope>0.1</Boomalope>
      <Toxalope MayRequire="Ludeon.RimWorld.Biotech">0.1</Toxalope>
      <Warg>0.05</Warg>
      <WasteRat MayRequire="Ludeon.RimWorld.Biotech">0.325</WasteRat>
      <Sparrow>0.8</Sparrow>
      <Crow>0.8</Crow>
      <BogHound>0.05</BogHound>
    </value>
  </Operation>
