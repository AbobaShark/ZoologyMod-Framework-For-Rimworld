    <xpath>/Defs/BiomeDef[defName="Scarlands"]/coastalWildAnimals</xpath>
    <value>
      <StoneCrab>1</StoneCrab>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Scarlands"]/allowedPackAnimals</xpath>
    <value>
      <li>Dromedary</li>
      <li>Horse</li>
      <li>Donkey</li>
    </value>
  </Operation>
</Patch>
