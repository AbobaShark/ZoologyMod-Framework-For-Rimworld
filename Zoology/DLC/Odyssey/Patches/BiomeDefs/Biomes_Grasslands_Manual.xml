<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <Operation Class="PatchOperationRemove">
    <xpath>/Defs/BiomeDef[defName="Grasslands"]/wildPlants/Plant_TreeOak</xpath>
  </Operation>

  <Operation Class="PatchOperationRemove">
    <xpath>/Defs/BiomeDef[defName="Grasslands"]/wildPlants/Plant_TreePoplar</xpath>
  </Operation>
  
  <Operation Class="PatchOperationRemove">
    <xpath>/Defs/BiomeDef[defName="Grasslands"]/wildPlants/Plant_HealrootWild</xpath>
  </Operation>
  
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Grasslands"]/wildPlants</xpath>
    <value>
      <Plant_Agave>0.2</Plant_Agave>
      <Plant_TreePalm>0.02</Plant_TreePalm>
      <Plant_TreeDrago>0.05</Plant_TreeDrago>
    </value>
  </Operation>
  
  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/BiomeDef[defName="Grasslands"]/animalDensity</xpath>
    <value>
      <animalDensity>4.55</animalDensity>
    </value>
  </Operation>
  
  <Operation Class="PatchOperationRemove">
    <xpath>/Defs/BiomeDef[defName="Grasslands"]/allowedPackAnimals/li[.="Muffalo"]</xpath>
  </Operation>
</Patch>
