<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	   
  <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName="ColossusToad"]/race/meatLabel</xpath>
    <match Class="PatchOperationReplace">
      <xpath>Defs/ThingDef[defName="ColossusToad"]/race/meatLabel</xpath>
      <value>
        <meatLabel>frog meat</meatLabel>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>Defs/ThingDef[defName="ColossusToad"]/race</xpath>
      <value>
        <meatLabel>frog meat</meatLabel>
      </value>
    </nomatch>
  </Operation>
  
  <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName="Seal"]/race/meatLabel</xpath>
    <match Class="PatchOperationReplace">
      <xpath>Defs/ThingDef[defName="Seal"]/race/meatLabel</xpath>
      <value>
        <meatLabel>pinniped meat</meatLabel>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>Defs/ThingDef[defName="Seal"]/race</xpath>
      <value>
        <meatLabel>pinniped meat</meatLabel>
      </value>
    </nomatch>
  </Operation>
  
  <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName="StoneCrab"]/race/meatLabel</xpath>
    <match Class="PatchOperationReplace">
      <xpath>Defs/ThingDef[defName="StoneCrab"]/race/meatLabel</xpath>
      <value>
        <meatLabel>crab meat</meatLabel>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>Defs/ThingDef[defName="StoneCrab"]/race</xpath>
      <value>
        <meatLabel>crab meat</meatLabel>
      </value>
    </nomatch>
  </Operation>

</Patch>