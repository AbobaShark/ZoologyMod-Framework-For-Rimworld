  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/PawnKindDef[defName = "Wolf_Great"]/lifeStages/li[1]/bodyGraphicData/drawSize</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/PawnKindDef[defName = "Wolf_Great"]/lifeStages/li[1]/bodyGraphicData/drawSize</xpath>
      <value><drawSize>1.1</drawSize></value>
    </match>
