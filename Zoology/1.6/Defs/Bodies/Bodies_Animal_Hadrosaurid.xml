<?xml version="1.0" encoding="utf-8" ?>

<!--
  Each coverage value is relative to its parent.
  Remaining body part coverage (100% minus coverage of all child nodes) is a chance to hit exactly this part.
  Damage "starts" at corePart, and then "goes deeper" until it hits remaining body part coverage or leaf node
  - this body part is then hit.
-->

<Defs>

  <!-- Hadrosaurid / iguanodont-like: front thumb spike as Spur -->
  <BodyDef>
    <defName>Hadrosaurid</defName>
    <label>hadrosaurid dinosaur</label>
    <corePart>
      <def>Body</def>
      <height>Middle</height>
      <depth>Outside</depth>
      <parts>
        <li>
          <def>Tail</def>
          <coverage>0.12</coverage>
          <groups>
            <li>TailAttackTool</li>
          </groups>
        </li>
        <li>
          <def>Spine</def>
          <coverage>0.025</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>Stomach</def>
          <coverage>0.025</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>Heart</def>
          <coverage>0.020</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>Lung</def>
          <customLabel>left lung</customLabel>
          <coverage>0.025</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>Lung</def>
          <customLabel>right lung</customLabel>
          <coverage>0.025</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>Kidney</def>
          <customLabel>left kidney</customLabel>
          <coverage>0.017</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>Kidney</def>
          <customLabel>right kidney</customLabel>
          <coverage>0.017</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>Liver</def>
          <coverage>0.025</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>Neck</def>
          <coverage>0.18</coverage>
          <height>Top</height>
          <parts>
            <li>
              <def>HeadWithEarHoles</def>
              <coverage>0.75</coverage>
              <groups>
                <li>HeadAttackTool</li>
              </groups>
              <parts>
                <li>
                  <def>Skull</def>
                  <coverage>0.22</coverage>
                  <depth>Inside</depth>
                  <parts>
                    <li>
                      <def>Brain</def>
                      <coverage>0.4</coverage>
                      <depth>Inside</depth>
                    </li>
                  </parts>
                </li>
                <li>
                  <def>Eye</def>
                  <customLabel>left eye</customLabel>
                  <coverage>0.035</coverage>
                </li>
                <li>
                  <def>Eye</def>
                  <customLabel>right eye</customLabel>
                  <coverage>0.035</coverage>
                </li>
                <li>
                  <def>Nose</def>
                  <coverage>0.06</coverage>
                </li>
                <li>
                  <def>AnimalJaw</def>
                  <coverage>0.15</coverage>
                  <groups>
                    <li>Teeth</li>
                  </groups>
                </li>
              </parts>
            </li>
          </parts>
        </li>
        <li>
          <def>Arm</def>
          <customLabel>front left arm</customLabel>
          <coverage>0.065</coverage>
          <height>Bottom</height>
          <parts>
            <li>
              <def>Hand</def>
              <customLabel>front left hand</customLabel>
              <coverage>0.15</coverage>
			  <groups>
				<li>FrontLeftSpur</li>
			  </groups>
            </li>
          </parts>
        </li>
        <li>
          <def>Arm</def>
          <customLabel>front right arm</customLabel>
          <coverage>0.065</coverage>
          <height>Bottom</height>
          <parts>
            <li>
              <def>Hand</def>
              <customLabel>front right hand</customLabel>
              <coverage>0.15</coverage>
			  <groups>
				<li>FrontRightSpur</li>
			  </groups>

            </li>
          </parts>
        </li>
        <li>
          <def>Leg</def>
          <customLabel>rear left leg</customLabel>
          <coverage>0.075</coverage>
          <height>Bottom</height>
		  <groups>
			<li>FrontLeftLeg</li>
		  </groups>
          <parts>
            <li>
              <def>Hoof</def>
              <customLabel>rear left hoof</customLabel>
              <coverage>0.15</coverage>
            </li>
          </parts>
        </li>
        <li>
          <def>Leg</def>
          <customLabel>rear right leg</customLabel>
          <coverage>0.075</coverage>
          <height>Bottom</height>
		  <groups>
			<li>FrontRightLeg</li>
		  </groups>
          <parts>
            <li>
              <def>Hoof</def>
              <customLabel>rear right hoof</customLabel>
              <coverage>0.15</coverage>
            </li>
          </parts>
        </li>
      </parts>
    </corePart>
  </BodyDef>

</Defs>