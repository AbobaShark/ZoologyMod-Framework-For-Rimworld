<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<BodyDef>
		<defName>Jellyfish</defName>
		<label>jellyfish</label>
		<corePart>
			<def>Mantle</def>
			<height>Middle</height>
			<depth>Outside</depth>
			<parts>
				<li>
					<def>Stomach</def>
					<customLabel>stomach pouch</customLabel>
					<coverage>0.05</coverage>
					<depth>Inside</depth>
				</li>
				<li>
					<def>Heart</def>
					<customLabel>gastrovascular cavity</customLabel>
					<coverage>0.03</coverage>
					<depth>Inside</depth>
				</li>
				<li>
					<def>HydrogenSac</def>
					<customLabel>left hydrogen sac</customLabel>
					<coverage>0.03</coverage>
					<depth>Inside</depth>
				</li>
				<li>
					<def>HydrogenSac</def>
					<customLabel>right hydrogen sac</customLabel>
					<coverage>0.03</coverage>
					<depth>Inside</depth>
				</li>
				<li>
					<def>Head</def>
				    <groups>
					  <li>HeadAttackTool</li>
				    </groups>
					<coverage>0.05</coverage>
					<parts>
						<li>
							<def>Eye</def>
							<customLabel>left eye spot</customLabel>
							<coverage>0.05</coverage>
						</li>
						<li>
							<def>Eye</def>
							<customLabel>right eye spot</customLabel>
							<coverage>0.05</coverage>
						</li>
						<li>
							<def>AnimalJaw</def>
							<coverage>0.02</coverage>
							<groups>
								<li>Teeth</li>
							</groups>
						</li>
					</parts>
				</li>
				<li>
					<def>Tentacle</def>
					<customLabel>first tentacle</customLabel>
					<groups>
						<li>Arms</li>
					</groups>
					<coverage>0.05</coverage>
					<height>Bottom</height>
				</li>
				<li>
					<def>Tentacle</def>
					<customLabel>second tentacle</customLabel>
					<groups>
						<li>Arms</li>
					</groups>
					<coverage>0.05</coverage>
					<height>Bottom</height>
				</li>
				<li>
					<def>Tentacle</def>
					<customLabel>third tentacle</customLabel>
					<groups>
						<li>Arms</li>
					</groups>
					<coverage>0.05</coverage>
					<height>Bottom</height>
				</li>
			</parts>
		</corePart>
	</BodyDef>

</Defs>
