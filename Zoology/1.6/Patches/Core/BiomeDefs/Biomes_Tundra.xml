<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="Tundra"]/wildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="Tundra"]/wildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Tundra"]</xpath>
    <value>
      <wildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="Tundra"]/pollutionWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="Tundra"]/pollutionWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Tundra"]</xpath>
    <value>
      <pollutionWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="Tundra"]/coastalWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="Tundra"]/coastalWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Tundra"]</xpath>
    <value>
      <coastalWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="Tundra"]/allowedPackAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="Tundra"]/allowedPackAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Tundra"]</xpath>
    <value>
      <allowedPackAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Tundra"]/wildAnimals</xpath>
    <value>
      <Bear_Polar>0.05</Bear_Polar>
      <Lynx>0.075</Lynx>
      <Snowhare>0.475</Snowhare>
      <Muffalo>0.15</Muffalo>
      <Caribou>0.175</Caribou>
      <Wolf_Arctic>0.05</Wolf_Arctic>
      <Fox_Arctic>0.1</Fox_Arctic>
      <Sparrow MayRequire="Ludeon.RimWorld.Odyssey">1</Sparrow>
      <Crow MayRequire="Ludeon.RimWorld.Odyssey">1</Crow>
      <Wolverine MayRequire="Ludeon.RimWorld.Odyssey">0.075</Wolverine>
      <Moose MayRequire="Ludeon.RimWorld.Odyssey">0.15</Moose>
      <Muskox MayRequire="Ludeon.RimWorld.Odyssey">0.15</Muskox>
      <AEXP_ArcticCoyote MayRequire="VanillaExpanded.VanillaAnimalsExpanded">0.075</AEXP_ArcticCoyote>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Tundra"]/pollutionWildAnimals</xpath>
    <value>
      <Sparrow MayRequire="Ludeon.RimWorld.Odyssey">0.8</Sparrow>
      <Crow MayRequire="Ludeon.RimWorld.Odyssey">0.8</Crow>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Tundra"]/coastalWildAnimals</xpath>
    <value>
      <Penguin MayRequire="Ludeon.RimWorld.Odyssey">0.25</Penguin>
      <SeaLion MayRequire="Ludeon.RimWorld.Odyssey">0.05</SeaLion>
      <Seal MayRequire="Ludeon.RimWorld.Odyssey">0.05</Seal>
      <Walrus MayRequire="Ludeon.RimWorld.Odyssey">0.125</Walrus>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="Tundra"]/allowedPackAnimals</xpath>
    <value>
      <li>Muffalo</li>
      <li>Horse</li>
    </value>
  </Operation>
</Patch>
