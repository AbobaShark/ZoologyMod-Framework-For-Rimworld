<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/wildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/wildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]</xpath>
    <value>
      <wildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/pollutionWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/pollutionWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]</xpath>
    <value>
      <pollutionWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/coastalWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/coastalWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]</xpath>
    <value>
      <coastalWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]</xpath>
    <value>
      <allowedPackAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/wildAnimals</xpath>
    <value>
      <Dromedary>0.15</Dromedary>
      <Donkey>0.15</Donkey>
      <Boomrat>0.15</Boomrat>
      <Fox_Fennec>0.1</Fox_Fennec>
      <Vulture MayRequire="Ludeon.RimWorld.Odyssey">0.1</Vulture>
      <Armadillo MayRequire="Ludeon.RimWorld.Odyssey">0.4</Armadillo>
      <AEXP_Boombat MayRequire="VanillaExpanded.VanillaAnimalsExpanded">0.15</AEXP_Boombat>
      <AEXP_DesertTortoise MayRequire="VanillaExpanded.VanillaAnimalsExpanded">0.25</AEXP_DesertTortoise>
      <AEXP_GilaMonster MayRequire="VanillaExpanded.VanillaAnimalsExpanded">0.65</AEXP_GilaMonster>
      <AEXP_Rattlesnake MayRequire="VanillaExpanded.VanillaAnimalsExpanded">0.4</AEXP_Rattlesnake>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/pollutionWildAnimals</xpath>
    <value>
      <Boomrat>0.25</Boomrat>
      <Vulture MayRequire="Ludeon.RimWorld.Odyssey">0.1</Vulture>
      <AEXP_Boombat MayRequire="VanillaExpanded.VanillaAnimalsExpanded">0.25</AEXP_Boombat>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/coastalWildAnimals</xpath>
    <value>
      <StoneCrab MayRequire="Ludeon.RimWorld.Odyssey">1</StoneCrab>
      <HermitCrab MayRequire="Ludeon.RimWorld.Odyssey">1</HermitCrab>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals</xpath>
    <value>
      <li>Dromedary</li>
      <li>Donkey</li>
      <li>Horse</li>
    </value>
  </Operation>
</Patch>
