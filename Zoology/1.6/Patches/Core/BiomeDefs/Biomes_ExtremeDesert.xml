<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/wildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/wildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]</xpath>
    <value>
      <wildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/pollutionWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/pollutionWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]</xpath>
    <value>
      <pollutionWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/coastalWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/coastalWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]</xpath>
    <value>
      <coastalWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]</xpath>
      <value>
        <allowedPackAnimals/>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/wildAnimals</xpath>
    <value>
      <Dromedary>0.15</Dromedary>
      <Donkey>0.175</Donkey>
      <Boomrat>0.15</Boomrat>
      <Fox_Fennec>0.125</Fox_Fennec>
      <Vulture MayRequire="Ludeon.RimWorld.Odyssey">0.375</Vulture>
      <Armadillo MayRequire="Ludeon.RimWorld.Odyssey">0.375</Armadillo>
      <AEXP_Boombat MayRequire="VanillaExpanded.VanillaAnimalsExpanded">0.125</AEXP_Boombat>
      <AEXP_DesertTortoise MayRequire="VanillaExpanded.VanillaAnimalsExpanded">0.225</AEXP_DesertTortoise>
      <AEXP_GilaMonster MayRequire="VanillaExpanded.VanillaAnimalsExpanded">0.5</AEXP_GilaMonster>
      <AEXP_Rattlesnake MayRequire="VanillaExpanded.VanillaAnimalsExpanded">0.375</AEXP_Rattlesnake>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/pollutionWildAnimals</xpath>
    <value>
      <Boomrat>0.15</Boomrat>
      <Toxalope MayRequire="Ludeon.RimWorld.Biotech">0.1</Toxalope>
      <WasteRat MayRequire="Ludeon.RimWorld.Biotech">0.325</WasteRat>
      <AEXP_Boombat MayRequire="VanillaExpanded.VanillaAnimalsExpanded">0.1</AEXP_Boombat>
      <VAEWaste_Hydra MayRequire="VanillaExpanded.VAEWaste">0.35</VAEWaste_Hydra>
      <VAEWaste_Megatardi MayRequire="VanillaExpanded.VAEWaste">0.075</VAEWaste_Megatardi>
      <VAEWaste_Toxscorpion MayRequire="VanillaExpanded.VAEWaste">0.15</VAEWaste_Toxscorpion>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/coastalWildAnimals</xpath>
    <value>
      <StoneCrab MayRequire="Ludeon.RimWorld.Odyssey">0.5</StoneCrab>
      <HermitCrab MayRequire="Ludeon.RimWorld.Odyssey">0.5</HermitCrab>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals/li[text()="Dromedary"]</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals</xpath>
      <value>
        <li>Dromedary</li>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals/li[text()="Donkey"]</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals</xpath>
      <value>
        <li>Donkey</li>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals/li[text()="VAEWaste_Megatardi"]</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals</xpath>
      <value>
        <li MayRequire="VanillaExpanded.VAEWaste">VAEWaste_Megatardi</li>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals/li[text()="Horse"]</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/BiomeDef[defName="ExtremeDesert"]/allowedPackAnimals</xpath>
      <value>
        <li>Horse</li>
      </value>
    </nomatch>
  </Operation>
</Patch>
