<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]/wildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="IceSheet"]/wildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]</xpath>
    <value>
      <wildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]/pollutionWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="IceSheet"]/pollutionWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]</xpath>
    <value>
      <pollutionWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]/coastalWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="IceSheet"]/coastalWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]</xpath>
    <value>
      <coastalWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]/allowedPackAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="IceSheet"]/allowedPackAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]</xpath>
    <value>
      <allowedPackAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]/wildAnimals</xpath>
    <value>
      <Bear_Polar>0.05</Bear_Polar>
      <Snowhare>0.475</Snowhare>
      <Fox_Arctic>0.1</Fox_Arctic>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]/pollutionWildAnimals</xpath>
    <value/>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]/coastalWildAnimals</xpath>
    <value>
      <Penguin MayRequire="Ludeon.RimWorld.Odyssey">0.25</Penguin>
      <SeaLion MayRequire="Ludeon.RimWorld.Odyssey">0.05</SeaLion>
      <Seal MayRequire="Ludeon.RimWorld.Odyssey">0.05</Seal>
      <Walrus MayRequire="Ludeon.RimWorld.Odyssey">0.125</Walrus>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="IceSheet"]/allowedPackAnimals</xpath>
    <value>
      <li>Muffalo</li>
      <li>Horse</li>
    </value>
  </Operation>
</Patch>
