<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]/wildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="SeaIce"]/wildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]</xpath>
    <value>
      <wildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]/pollutionWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="SeaIce"]/pollutionWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]</xpath>
    <value>
      <pollutionWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]/coastalWildAnimals</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/BiomeDef[defName="SeaIce"]/coastalWildAnimals</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]</xpath>
    <value>
      <coastalWildAnimals/>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]/allowedPackAnimals</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/BiomeDef[defName="SeaIce"]</xpath>
      <value>
        <allowedPackAnimals/>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]/wildAnimals</xpath>
    <value>
      <Bear_Polar>0.05</Bear_Polar>
      <Snowhare>0.425</Snowhare>
      <Fox_Arctic>0.1</Fox_Arctic>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]/pollutionWildAnimals</xpath>
    <value>
      <VAEWaste_Megatardi MayRequire="VanillaExpanded.VAEWaste">0.075</VAEWaste_Megatardi>
    </value>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]/coastalWildAnimals</xpath>
    <value>
      <Penguin MayRequire="Ludeon.RimWorld.Odyssey">0.25</Penguin>
      <SeaLion MayRequire="Ludeon.RimWorld.Odyssey">0.05</SeaLion>
      <Seal MayRequire="Ludeon.RimWorld.Odyssey">0.05</Seal>
      <Walrus MayRequire="Ludeon.RimWorld.Odyssey">0.125</Walrus>
      <AEXP_RockhopperPenguin MayRequire="VanillaExpanded.VAEEndAndExt">0.05</AEXP_RockhopperPenguin>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]/allowedPackAnimals/li[text()="VAEWaste_Megatardi"]</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/BiomeDef[defName="SeaIce"]/allowedPackAnimals</xpath>
      <value>
        <li MayRequire="VanillaExpanded.VAEWaste">VAEWaste_Megatardi</li>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]/allowedPackAnimals/li[text()="Muffalo"]</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/BiomeDef[defName="SeaIce"]/allowedPackAnimals</xpath>
      <value>
        <li>Muffalo</li>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/BiomeDef[defName="SeaIce"]/allowedPackAnimals/li[text()="Horse"]</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/BiomeDef[defName="SeaIce"]/allowedPackAnimals</xpath>
      <value>
        <li>Horse</li>
      </value>
    </nomatch>
  </Operation>
</Patch>
