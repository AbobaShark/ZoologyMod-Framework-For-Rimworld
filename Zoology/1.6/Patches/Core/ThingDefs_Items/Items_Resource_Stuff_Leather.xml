  <!-- Fox -->
  <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName="Leather_Fox"]/statBases/MarketValue</xpath>
    <match Class="PatchOperationReplace">
      <xpath>Defs/ThingDef[defName="Leather_Fox"]/statBases/MarketValue</xpath>
      <value><MarketValue>4.6</MarketValue></value>
    </match>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName="Leather_Fox"]/stuffProps/statFactors/Beauty</xpath>
    <match Class="PatchOperationReplace">
      <xpath>Defs/ThingDef[defName="Leather_Fox"]/stuffProps/statFactors/Beauty</xpath>
      <value><Beauty>2.7</Beauty></value>
    </match>
  </Operation>

  <!-- =======================================================================
       4) Combat Extended-specific balancing
       ======================================================================= -->
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Combat Extended</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>

        <!-- Squirrel -->
        <li Class="PatchOperationConditional">
          <xpath>Defs/ThingDef[defName="Leather_Squirrel"]/statBases/StuffPower_Armor_Sharp</xpath>
          <match Class="PatchOperationReplace">
            <xpath>Defs/ThingDef[defName="Leather_Squirrel"]/statBases/StuffPower_Armor_Sharp</xpath>
            <value><StuffPower_Armor_Sharp>0.03</StuffPower_Armor_Sharp></value>
          </match>
        </li>

        <li Class="PatchOperationConditional">
          <xpath>Defs/ThingDef[defName="Leather_Squirrel"]/statBases/StuffPower_Armor_Blunt</xpath>
