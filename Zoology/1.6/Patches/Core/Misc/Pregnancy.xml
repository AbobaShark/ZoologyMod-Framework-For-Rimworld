<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <!-- Точечные добавления hungerRateFactorOffset в стадии HediffDef 'Pregnant' (животные).
       Значения: стадия 1 = 0.05, стадия 2 = 0.15, стадия 3 = 0.25 -->
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/HediffDef[defName="Pregnant"]/stages/li[1]</xpath>
    <value>
      <hungerRateFactorOffset>0.05</hungerRateFactorOffset>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/HediffDef[defName="Pregnant"]/stages/li[2]</xpath>
    <value>
      <hungerRateFactorOffset>0.15</hungerRateFactorOffset>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/HediffDef[defName="Pregnant"]/stages/li[3]</xpath>
    <value>
      <hungerRateFactorOffset>0.25</hungerRateFactorOffset>
    </value>
  </Operation>
  
</Patch>