    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/PawnKindDef[defName = "Panther"]/lifeStages/li[1]/bodyGraphicData</xpath>
      <value>
        <texPath>Things/Pawn/Animal/Panther/Panther</texPath>
