<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- GuineaPig -->
  
  <!-- Set drawSize for life stage 2 (intermediate: 0.625) -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[2]/bodyGraphicData/drawSize</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[2]/bodyGraphicData/drawSize</xpath>
      <value>
        <drawSize>0.625</drawSize>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[2]/bodyGraphicData</xpath>
      <value>
        <drawSize>0.625</drawSize>
      </value>
    </nomatch>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[2]/dessicatedBodyGraphicData/drawSize</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[2]/dessicatedBodyGraphicData/drawSize</xpath>
      <value>
        <drawSize>0.625</drawSize>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[2]/dessicatedBodyGraphicData</xpath>
      <value>
        <drawSize>0.625</drawSize>
      </value>
    </nomatch>
  </Operation>

  <!-- Set drawSize for life stage 3 (target: 0.75) -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[3]/bodyGraphicData/drawSize</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[3]/bodyGraphicData/drawSize</xpath>
      <value>
        <drawSize>0.75</drawSize>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[3]/bodyGraphicData</xpath>
      <value>
        <drawSize>0.75</drawSize>
      </value>
    </nomatch>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[3]/dessicatedBodyGraphicData/drawSize</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[3]/dessicatedBodyGraphicData/drawSize</xpath>
      <value>
        <drawSize>0.75</drawSize>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/PawnKindDef[defName = "GuineaPig"]/lifeStages/li[3]/dessicatedBodyGraphicData</xpath>
      <value>
        <drawSize>0.75</drawSize>
      </value>
    </nomatch>
  </Operation>
  
</Patch>