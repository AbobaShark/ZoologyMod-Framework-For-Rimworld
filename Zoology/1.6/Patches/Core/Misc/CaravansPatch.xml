<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!-- Outlander: Horse -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/FactionDef[@Name="OutlanderFactionBase"]/pawnGroupMakers/li[kindDef="Trader"]/carriers/Horse</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/FactionDef[@Name="OutlanderFactionBase"]/pawnGroupMakers/li[kindDef="Trader"]/carriers/Horse</xpath>
      <value>
        <Horse>10</Horse>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/FactionDef[@Name="OutlanderFactionBase"]/pawnGroupMakers/li[kindDef="Trader"]/carriers</xpath>
      <value>
        <Horse>10</Horse>
      </value>
    </nomatch>
  </Operation>

