<?xml version='1.0' encoding='utf-8'?>
<Defs>
  <ThingDef ParentName="PhotonozoaThingBase">
    <defName>Arthropython</defName>
    <label>arthropython</label>
    <description>The Arthropython may seem sluggish beside other photonozoan predators, yet underestimating it is a fatal mistake. Beneath its segmented armor coils a patient killer — silent, deliberate, and merciless. Its bladed limbs strike with surgical precision, impaling prey before they even realize they’ve been hunted.

	Even in stillness, there is intent in its motion — a quiet sense that it studies, learns, evolves. For the Arthropython is not yet complete. What it becomes when it grows is beyond nightmare, and far beyond mercy.</description>
    <statBases>
      <MoveSpeed>3</MoveSpeed>
      <MarketValue>1250</MarketValue>
      <FilthRate>1</FilthRate>
      <ArmorRating_Blunt>0.8</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.2</ArmorRating_Sharp>
      <ArmorRating_Heat>0.25</ArmorRating_Heat>
      <ComfyTemperatureMin>-160</ComfyTemperatureMin>
    </statBases>
    <race>
      <body>Xenosnake</body>
      <predator>true</predator>
      <baseBodySize>0.85</baseBodySize>
      <baseHungerRate>0.5</baseHungerRate>
      <baseHealthScale>1</baseHealthScale>
      <foodType>CarnivoreAnimalStrict, OvivoreAnimal</foodType>
      <leatherDef>Leather_PhotonozoaM</leatherDef>
      <nameOnTameChance>0</nameOnTameChance>
      <specialTrainables>
        <li MayRequire="Ludeon.RimWorld.Odyssey">Dig</li>
      </specialTrainables>
      <manhunterOnTameFailChance>1</manhunterOnTameFailChance>
      <manhunterOnDamageChance>1</manhunterOnDamageChance>
      <lifeExpectancy>5</lifeExpectancy>
      <lifeStageAges>
        <li>
          <def>PhotonozoaLarvaSmall</def>
          <minAge>0.0</minAge>
        </li>
        <li>
          <def>PhotonozoaLarvaMedium</def>
          <minAge>0.2</minAge>
        </li>
        <li>
          <def>PhotonozoaLarvaLarge</def>
          <minAge>0.4</minAge>
          <soundWounded>Pawn_Cobra_Wounded</soundWounded>
          <soundDeath>Pawn_Cobra_Death</soundDeath>
          <soundCall>Pawn_Cobra_Call</soundCall>
          <soundAngry>Pawn_Cobra_Angry</soundAngry>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_SmallScratch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_SmallScratch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_SmallScratch_Miss</soundMeleeMiss>
      <soundEating>Reptile_Eat</soundEating>
      <headPosPerRotation>
        <li>(-0.03, 0, 0.35)</li>
        <li>(0.03, 0, 0.36)</li>
        <li>(-0.05, 0, 0.28)</li>
        <li>(-0.03, 0, 0.36)</li>
      </headPosPerRotation>
      <maxPreyBodySize>1.5</maxPreyBodySize>
      <waterCellCost>10</waterCellCost>
      <canFishForFood>true</canFishForFood>
      <trainability>None</trainability>
    </race>
    <modExtensions>
      <li Class="PhotonozoaMod.PhotonozoaTerritorialExtension, PhotonozoaMod">
        <isTerritorial>true</isTerritorial>
        <targetAcquireRadius>6</targetAcquireRadius>
        <targetKeepRadius>9</targetKeepRadius>
      </li>
      <li Class="PhotonozoaMod.PhotonozoaProperties">
      </li>
      <li Class="PhotonozoaMod.PhotonozoaRaceExtension, PhotonozoaMod">
        <diet>Carnivore</diet>
        <!-- Carnivore / Omnivore / Herbivore -->
      </li>
    </modExtensions>
    <comps>
      <li Class="PhotonozoaMod.CompProperties_PawnToCocoon, PhotonozoaMod">
        <cocoonDef>ArthropythonCocoon</cocoonDef>
        <jobDefToPupate>Pupate</jobDefToPupate>
        <showMetamorphosisMessage>true</showMetamorphosisMessage>
        <showMetamorphosisMessageTamed>true</showMetamorphosisMessageTamed>
      </li>
    </comps>
    <tools>
      <li>
        <label>head</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>6.5</power>
        <cooldownTime>1.9</cooldownTime>
        <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
        <chanceFactor>0.2</chanceFactor>
      </li>
      <li>
        <label>left claw</label>
        <labelNoLocation>claw</labelNoLocation>
        <capacities>
          <li>Scratch</li>
        </capacities>
        <power>16</power>
        <cooldownTime>0.5</cooldownTime>
        <linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>20</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
      </li>
      <li>
        <label>right claw</label>
        <labelNoLocation>claw</labelNoLocation>
        <capacities>
          <li>Scratch</li>
        </capacities>
        <power>16</power>
        <cooldownTime>0.5</cooldownTime>
        <linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>20</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
      </li>
      <li>
        <label>teeth</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>15</power>
        <cooldownTime>1.15</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>20</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
      </li>
    </tools>
  </ThingDef>
