<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <!-- Combat Extended patch for Paragnathus (no FindMod wrapper) -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/MeleeDodgeChance</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/MeleeDodgeChance</xpath>
      <value>
        <MeleeDodgeChance>0.47</MeleeDodgeChance>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases</xpath>
      <value>
        <MeleeDodgeChance>0.47</MeleeDodgeChance>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/MeleeCritChance</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/MeleeCritChance</xpath>
      <value>
        <MeleeCritChance>0.53</MeleeCritChance>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases</xpath>
      <value>
        <MeleeCritChance>0.53</MeleeCritChance>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/MeleeParryChance</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/MeleeParryChance</xpath>
      <value>
        <MeleeParryChance>0.21</MeleeParryChance>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases</xpath>
      <value>
        <MeleeParryChance>0.21</MeleeParryChance>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/ArmorRating_Sharp</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/ArmorRating_Sharp</xpath>
      <value>
        <ArmorRating_Sharp>0.51</ArmorRating_Sharp>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases</xpath>
      <value>
        <ArmorRating_Sharp>0.51</ArmorRating_Sharp>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/ArmorRating_Blunt</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/ArmorRating_Blunt</xpath>
      <value>
        <ArmorRating_Blunt>3.08</ArmorRating_Blunt>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases</xpath>
      <value>
        <ArmorRating_Blunt>3.08</ArmorRating_Blunt>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Paragnathus"]/comps</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]</xpath>
      <value>
        <comps/>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Paragnathus"]/comps/li[@Class="CombatExtended.CompProperties_ArmorDurability"]</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/comps/li[@Class="CombatExtended.CompProperties_ArmorDurability"]/Durability</xpath>
      <value>
        <Durability>625</Durability>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/comps</xpath>
      <value>
        <li Class="CombatExtended.CompProperties_ArmorDurability">
          <Durability>625</Durability>
          <Regenerates>true</Regenerates>
          <RegenInterval>600</RegenInterval>
          <RegenValue>5</RegenValue>
          <MinArmorPct>0.5</MinArmorPct>
        </li>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Paragnathus"]/modExtensions/li[@Class="CombatExtended.RacePropertiesExtensionCE"]</xpath>
    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationConditional">
          <xpath>/Defs/ThingDef[defName = "Paragnathus"]/modExtensions/li[@Class="CombatExtended.RacePropertiesExtensionCE"]/bodyShape</xpath>
          <match Class="PatchOperationReplace">
            <xpath>/Defs/ThingDef[defName = "Paragnathus"]/modExtensions/li[@Class="CombatExtended.RacePropertiesExtensionCE"]/bodyShape</xpath>
            <value>
              <bodyShape>QuadrupedLow</bodyShape>
            </value>
          </match>
          <nomatch Class="PatchOperationAdd">
            <xpath>/Defs/ThingDef[defName = "Paragnathus"]/modExtensions/li[@Class="CombatExtended.RacePropertiesExtensionCE"]</xpath>
            <value>
              <bodyShape>QuadrupedLow</bodyShape>
            </value>
          </nomatch>
        </li>
      </operations>
    </match>
    <nomatch Class="PatchOperationAddModExtension">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]</xpath>
      <value>
        <li Class="CombatExtended.RacePropertiesExtensionCE">
          <bodyShape>QuadrupedLow</bodyShape>
        </li>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Paragnathus"]/tools</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/tools</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/ThingDef[defName = "Paragnathus"]</xpath>
    <value>
      <tools>
        <li Class="CombatExtended.ToolCE">
          <label>head</label>
          <capacities>
            <li>Blunt</li>
          </capacities>
          <power>2.3</power>
          <armorPenetrationBlunt>2.59</armorPenetrationBlunt>
          <cooldownTime>1.65</cooldownTime>
          <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
          <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
          <chanceFactor>0.2</chanceFactor>
        </li>
      </tools>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/ArmorRating_Heat</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/ThingDef[defName = "Paragnathus"]/statBases/ArmorRating_Heat</xpath>
    </match>
  </Operation>
</Patch>