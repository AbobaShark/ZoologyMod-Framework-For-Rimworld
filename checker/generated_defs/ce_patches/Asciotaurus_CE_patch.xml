          <armorPenetrationBlunt>91.55</armorPenetrationBlunt>
          <cooldownTime>2.3</cooldownTime>
          <linkedBodyPartsGroup>FrontRightLeg</linkedBodyPartsGroup>
        </li>
        <li Class="CombatExtended.ToolCE">
          <label>horn</label>
          <capacities>
            <li>Scratch</li>
          </capacities>
          <power>75.1</power>
          <armorPenetrationBlunt>108.62</armorPenetrationBlunt>
          <armorPenetrationSharp>46.64</armorPenetrationSharp>
          <cooldownTime>2.9</cooldownTime>
          <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
        </li>
      </tools>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Asciotaurus"]/statBases/ArmorRating_Heat</xpath>
