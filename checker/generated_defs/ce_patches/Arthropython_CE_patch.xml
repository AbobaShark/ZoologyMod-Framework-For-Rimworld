<?xml version='1.0' encoding='utf-8'?>
<Patch>
  <!-- Combat Extended patch for Arthropython (no FindMod wrapper) -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/MeleeDodgeChance</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/MeleeDodgeChance</xpath>
      <value>
        <MeleeDodgeChance>0.52</MeleeDodgeChance>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases</xpath>
      <value>
        <MeleeDodgeChance>0.52</MeleeDodgeChance>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/MeleeCritChance</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/MeleeCritChance</xpath>
      <value>
        <MeleeCritChance>0.67</MeleeCritChance>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases</xpath>
      <value>
        <MeleeCritChance>0.67</MeleeCritChance>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/MeleeParryChance</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/MeleeParryChance</xpath>
      <value>
        <MeleeParryChance>0.29</MeleeParryChance>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases</xpath>
      <value>
        <MeleeParryChance>0.29</MeleeParryChance>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/ArmorRating_Sharp</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/ArmorRating_Sharp</xpath>
      <value>
        <ArmorRating_Sharp>0.26</ArmorRating_Sharp>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases</xpath>
      <value>
        <ArmorRating_Sharp>0.26</ArmorRating_Sharp>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/ArmorRating_Blunt</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/ArmorRating_Blunt</xpath>
      <value>
        <ArmorRating_Blunt>1.54</ArmorRating_Blunt>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases</xpath>
      <value>
        <ArmorRating_Blunt>1.54</ArmorRating_Blunt>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Arthropython"]/comps</xpath>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]</xpath>
      <value>
        <comps/>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Arthropython"]/comps/li[@Class="CombatExtended.CompProperties_ArmorDurability"]</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/comps/li[@Class="CombatExtended.CompProperties_ArmorDurability"]/Durability</xpath>
      <value>
        <Durability>462.5</Durability>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/comps</xpath>
      <value>
        <li Class="CombatExtended.CompProperties_ArmorDurability">
          <Durability>462.5</Durability>
          <Regenerates>true</Regenerates>
          <RegenInterval>600</RegenInterval>
          <RegenValue>5</RegenValue>
          <MinArmorPct>0.5</MinArmorPct>
        </li>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Arthropython"]/modExtensions/li[@Class="CombatExtended.RacePropertiesExtensionCE"]</xpath>
    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationConditional">
          <xpath>/Defs/ThingDef[defName = "Arthropython"]/modExtensions/li[@Class="CombatExtended.RacePropertiesExtensionCE"]/bodyShape</xpath>
          <match Class="PatchOperationReplace">
            <xpath>/Defs/ThingDef[defName = "Arthropython"]/modExtensions/li[@Class="CombatExtended.RacePropertiesExtensionCE"]/bodyShape</xpath>
            <value>
              <bodyShape>Serpentine</bodyShape>
            </value>
          </match>
          <nomatch Class="PatchOperationAdd">
            <xpath>/Defs/ThingDef[defName = "Arthropython"]/modExtensions/li[@Class="CombatExtended.RacePropertiesExtensionCE"]</xpath>
            <value>
              <bodyShape>Serpentine</bodyShape>
            </value>
          </nomatch>
        </li>
      </operations>
    </match>
    <nomatch Class="PatchOperationAddModExtension">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]</xpath>
      <value>
        <li Class="CombatExtended.RacePropertiesExtensionCE">
          <bodyShape>Serpentine</bodyShape>
        </li>
      </value>
    </nomatch>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Arthropython"]/tools</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/tools</xpath>
    </match>
  </Operation>
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/ThingDef[defName = "Arthropython"]</xpath>
    <value>
      <tools>
        <li Class="CombatExtended.ToolCE">
          <label>head</label>
          <capacities>
            <li>Blunt</li>
          </capacities>
          <power>1.2</power>
          <armorPenetrationBlunt>1.38</armorPenetrationBlunt>
          <cooldownTime>1.85</cooldownTime>
          <linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
          <ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
          <chanceFactor>0.2</chanceFactor>
        </li>
        <li Class="CombatExtended.ToolCE">
          <label>left claw</label>
          <labelNoLocation>claw</labelNoLocation>
          <capacities>
            <li>Scratch</li>
          </capacities>
          <power>18.8</power>
          <armorPenetrationBlunt>4.61</armorPenetrationBlunt>
          <armorPenetrationSharp>3.18</armorPenetrationSharp>
          <cooldownTime>1.35</cooldownTime>
          <linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
          <surpriseAttack>
            <extraMeleeDamages>
              <li>
                <def>Stun</def>
                <amount>20</amount>
              </li>
            </extraMeleeDamages>
          </surpriseAttack>
        </li>
        <li Class="CombatExtended.ToolCE">
          <label>right claw</label>
          <labelNoLocation>claw</labelNoLocation>
          <capacities>
            <li>Scratch</li>
          </capacities>
          <power>18.8</power>
          <armorPenetrationBlunt>4.61</armorPenetrationBlunt>
          <armorPenetrationSharp>3.18</armorPenetrationSharp>
          <cooldownTime>1.35</cooldownTime>
          <linkedBodyPartsGroup>FrontRightPaw</linkedBodyPartsGroup>
          <surpriseAttack>
            <extraMeleeDamages>
              <li>
                <def>Stun</def>
                <amount>20</amount>
              </li>
            </extraMeleeDamages>
          </surpriseAttack>
        </li>
        <li Class="CombatExtended.ToolCE">
          <label>teeth</label>
          <capacities>
            <li>Bite</li>
          </capacities>
          <power>14.1</power>
          <armorPenetrationBlunt>5.76</armorPenetrationBlunt>
          <armorPenetrationSharp>3.97</armorPenetrationSharp>
          <cooldownTime>1.25</cooldownTime>
          <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
          <surpriseAttack>
            <extraMeleeDamages>
              <li>
                <def>Stun</def>
                <amount>20</amount>
              </li>
            </extraMeleeDamages>
          </surpriseAttack>
        </li>
      </tools>
    </value>
  </Operation>
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/ArmorRating_Heat</xpath>
    <match Class="PatchOperationRemove">
      <xpath>/Defs/ThingDef[defName = "Arthropython"]/statBases/ArmorRating_Heat</xpath>
    </match>
  </Operation>
</Patch>